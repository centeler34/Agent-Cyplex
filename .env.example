# Agent Cyplex — Environment Variables (Example)
# Copy to .env and fill in your values. Never commit .env to version control.

# AI Provider API Keys (stored encrypted in keystore at runtime — these are only for initial setup)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=...

# Bot Tokens (stored encrypted in keystore at runtime)
TELEGRAM_BOT_TOKEN=...
DISCORD_BOT_TOKEN=...

# Local AI Backends (no keys needed, just endpoints)
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Daemon Configuration
CYPLEX_SOCKET_PATH=/tmp/cyplex.sock
CYPLEX_LOG_LEVEL=info
